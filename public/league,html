<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:'General Sans',sans-serif;background:#0a0a0a;color:#fafaf9;line-height:1.6}
:root{--black:#0a0a0a;--black2:#131313;--black3:#1a1a1a;--orange:#e8611a;--orange-light:#f4832f;--white:#fafaf9;--gray:#8a8a8a;--green:#22c55e;--red:#ef4444;--gold:#f4c542}
