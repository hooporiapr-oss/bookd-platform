document.getElementById('tabs').addEventListener('click',function(e){var tab=e.target.closest('.tab');if(!tab)return;var n=tab.dataset.tab;document.querySelectorAll('.tab').forEach(function(t){t.classList.remove('active')});tab.classList.add('active');document.querySelectorAll('.panel').forEach(function(p){p.classList.remove('active')});var p=document.getElementById('panel-'+n);if(p)p.classList.add('active')});

function renderHero(){var t=tournament;document.getElementById('heroBadge').textContent=(t.format_type||'League').toUpperCase();document.getElementById('heroTitle').textContent=t.name_en||'';document.getElementById('heroSub').textContent=(t.operators?t.operators.business_name:'')+(t.location?' · '+t.location:'');var completed=matches.filter(function(m){return m.status==='completed'}).length;var live=matches.filter(function(m){return m.status==='live'}).length;var h='<div class="hero-stat"><div class="hero-stat-val">'+teams.length+'</div><div class="hero-stat-label"><span class="en">Teams</span><span class="es">Equipos</span></div></div><div class="hero-stat"><div class="hero-stat-val">'+matches.length+'</div><div class="hero-stat-label"><span class="en">Games</span><span class="es">Juegos</span></div></div><div class="hero-stat"><div class="hero-stat-val">'+completed+'</div><div class="hero-stat-label"><span class="en">Played</span><span class="es">Jugados</span></div></div>';if(live>0)h+='<div class="hero-stat"><div class="hero-stat-val" style="color:var(--red)">'+live+'</div><div class="hero-stat-label"><span class="en">Live</span><span class="es">En Vivo</span></div></div>';document.getElementById('heroStats').innerHTML=h;setLang(currentLang)}

