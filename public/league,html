function renderRosters(){var g=document.getElementById('rosterGrid');if(!teams.length){g.innerHTML='<div class="empty-state"><div class="icon">👥</div><p><span class="en">No teams registered</span><span class="es">Sin equipos</span></p></div>';setLang(currentLang);return}g.innerHTML=teams.map(function(t){var p=rosters.filter(function(r){return r.tournament_team_id===t.id}),ph=p.length?p.map(function(r){return '<div class="player-row"><div class="player-num">'+(r.jersey_number||'—')+'</div><div class="player-name">'+esc(r.player_name)+'</div>'+(r.position?'<div class="player-pos">'+esc(r.position)+'</div>':'')+'</div>'}).join(''):'<p style="font-size:.8rem;color:var(--gray);padding:8px 0"><span class="en">No roster</span><span class="es">Sin roster</span></p>';return '<div class="roster-card"><h3>'+esc(t.team_name)+'</h3>'+(t.coach_name?'<div class="coach">Coach: '+esc(t.coach_name)+'</div>':'')+ph+'</div>'}).join('');setLang(currentLang)}

