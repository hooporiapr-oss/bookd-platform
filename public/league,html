function renderPlayoffs(){var pm=matches.filter(function(m){return m.round>=90});if(!pm.length)return;var c=document.getElementById('playoffContent'),rounds={};pm.forEach(function(m){if(!rounds[m.round])rounds[m.round]=[];rounds[m.round].push(m)});var rn={'90':'Quarterfinals','91':'Semifinals','92':'Finals','93':'Championship'},h='<div class="bracket-wrap"><div class="bracket">';Object.keys(rounds).sort().forEach(function(r){h+='<div class="bracket-round"><div class="bracket-round-title">'+(rn[r]||'Round '+r)+'</div>';rounds[r].forEach(function(m){var a=teams.find(function(t){return t.id===m.team_a_id}),b=teams.find(function(t){return t.id===m.team_b_id}),f=r>='92',ca=m.winner_id===m.team_a_id?'winner':'',cb=m.winner_id===m.team_b_id?'winner':'';h+='<div class="bracket-match'+(f?' final':'')+'"><div class="bracket-slot '+ca+'"><span class="bs-name">'+(a?esc(a.team_name):'TBD')+'</span><span class="bs-score">'+(m.score_a!==null?m.score_a:'')+'</span></div><div class="bracket-slot '+cb+'"><span class="bs-name">'+(b?esc(b.team_name):'TBD')+'</span><span class="bs-score">'+(m.score_b!==null?m.score_b:'')+'</span></div></div>'});h+='</div>'});h+='</div></div>';var fin=pm.find(function(m){return m.winner_id&&m.round>=92});if(fin){var ch=teams.find(function(t){return t.id===fin.winner_id});if(ch)h+='<div class="champion"><div class="trophy">🏆</div><h3>'+esc(ch.team_name)+'</h3><div class="tag"><span class="en">Champion</span><span class="es">Campeón</span></div></div>'}c.innerHTML=h;setLang(currentLang)}

