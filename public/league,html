function renderSchedule(){var l=document.getElementById('scheduleList');if(!matches.length){l.innerHTML='<div class="empty-state"><div class="icon">📅</div><p><span class="en">No games scheduled</span><span class="es">Sin juegos</span></p></div>';setLang(currentLang);return}l.innerHTML=matches.map(function(m){var a=teams.find(function(t){return t.id===m.team_a_id}),b=teams.find(function(t){return t.id===m.team_b_id}),na=a?a.team_name:'TBD',nb=b?b.team_name:'TBD',done=m.status==='completed',liv=m.status==='live',ca=done&&m.winner_id===m.team_a_id?'winner':(done?'loser':''),cb=done&&m.winner_id===m.team_b_id?'winner':(done?'loser':''),dt=m.scheduled_at?new Date(m.scheduled_at).toLocaleDateString():'';return '<div class="game-card'+(liv?' live':'')+'"><div class="game-header"><span>R'+m.round+' · G'+m.match_number+(m.court?' · '+m.court:'')+'</span>'+(liv?'<span class="live-badge">LIVE</span>':'<span>'+dt+'</span>')+'</div><div class="game-teams"><div class="game-team '+ca+'"><div class="game-team-name">'+esc(na)+'</div></div><div class="game-score">'+(m.score_a!==null?m.score_a:'-')+'<span>-</span>'+(m.score_b!==null?m.score_b:'-')+'</div><div class="game-team '+cb+'" style="text-align:right"><div class="game-team-name">'+esc(nb)+'</div></div></div></div>'}).join('');setLang(currentLang)}

